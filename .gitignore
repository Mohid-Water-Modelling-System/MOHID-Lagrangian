#|==================================================================================|#
#|				Build directories, binaries and External libraries					|#
#|==================================================================================|#
# Ignore all content within any build directory by default
**/build/*

# Specifically allow bin and lib directories and their contents
!**/build/bin/
!**/build/bin/**
!**/build/lib/
!**/build/lib/**

# Specific build script exclusions
buildScripts/build/
buildScripts/MOHID-Lagrangian/
buildScripts/src/
build/bin/RELEASE/MOHIDLagrangian.exe


#|==================================================================================|#
#|				Editor and IDE settings												|#
#|==================================================================================|#
.vscode
.vs/VSWorkspaceState.json
.vs/slnx.sqlite
.vs/ProjectSettings.json
.vs/MOHID-Lagrangian/v16/.suo
.vs/cmake.db
.vs/CMake Overview

